    <!-- Home Screen - Home Greetings -->
    <string name="home_greeting_1">Qué aplicación desexa parchear?</string>
    <!-- Humorous hype message with light nostalgia -->
    <string name="home_greeting_2">Listo para facer as aplicacións lexendarias de novo?</string>
    <!-- "Buckle up" referring to fastening your vehicle seat belt. A light-hearted joke to build excitement -->
    <string name="home_greeting_3">Abroche o cinto, é a hora dos parches</string>
    <!-- Sarcastic joke about blocking ads, intentionally over-the-top -->
    <string name="home_greeting_4">Outro día máis, outra obra mestra con bloqueo de anuncios</string>
    <!-- "Watch ads" refers to watching video ads in unpatched apps -->
    <string name="home_greeting_5">Quere ver anuncios? Eu tampouco</string>
    <!-- Friendly, slightly mischievous joke about controlling app behavior -->
    <string name="home_greeting_6">Faga que as súas aplicacións se comporten</string>
    <!-- Whimsical forecast-style joke, not meant literally -->
    <string name="home_greeting_7">Previsión do día: 100% de probabilidade de parcheo</string>
    <!-- From mediocrity to amazing -->
    <string name="home_greeting_8">Listo para transformar o mediocre en algo incrible?</string>
    <!-- Playful exaggeration, making patching feel heroic -->
    <string name="home_greeting_9">Salvando as aplicacións de si mesmas dende hoxe</string>
    <!-- Light sarcasm, casual and tech-savvy humor -->
    <string name="home_greeting_10">Propulsado por cafeína e bos parches</string>
