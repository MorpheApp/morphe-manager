    <string name="morphe_patcher_message_1">Pretvaranje vaše aplikacije u nešto sjajno… 🏆</string>
    <string name="morphe_patcher_message_2">Učimo starim aplikacijama nove trikove… 🎩</string>
    <string name="morphe_patcher_message_3">Dodajte digitalnoj popravci vašoj aplikaciji… 🔧</string>
    <string name="morphe_patcher_message_4">Kuhanje digitalne magije… ☕</string>
    <string name="morphe_patcher_message_5">Preporučeno odmor… ☕</string>
    <string name="morphe_patcher_message_6">Pogledaj van, lijepo je tamo… 🌤️</string>
    <string name="morphe_patcher_message_7">Podesavanje 1-ova i 0-ova… 🤖</string>
    <string name="morphe_patcher_message_8">Razmotati digitalni špageti… 🍝</string>
    <!-- Morphe patches fix YouTube bugs that Google still has not fixed. -->
    <string name="morphe_patcher_message_9">Popravljam greške u nepatchiranom aplikaciji… 🐞</string>
    <string name="morphe_patcher_message_10">Veličani ispuni su vrijedni za čekanje… ⏳</string>
    <string name="morphe_patcher_message_11">Poliranje piksela do sjaja… 💎</string>
    <string name="morphe_patcher_message_12">Molimo ostanite sjedili do kada kapetan isključi znak \"Patching in progress\"… 💺✈️</string>
    <string name="morphe_patcher_message_13">Kuhate vašu ispravljenu aplikaciju, toplo i svježe… 🍳</string>
    <!-- "bytecode" can be translated from "the app code" -->
    <string name="morphe_patcher_message_14">Pregovarati polito s bajtkodom… 🤝</string>
    <!-- Space flight communications callout. -->
    <string name="morphe_patcher_message_15">Svi sistemi nominalni… putanja je stabilna… 🚀</string>
    <string name="morphe_patcher_message_16">Izguravaju dodatnu snagu, kao sok od digitalnog limuna… 🍋</string>
    <string name="morphe_patcher_message_17">Pozivati aplikaciju da prihvati svoju novu, bolju verziju… 🌱</string>
    <!-- Quantum physics (box emoji is a reference to Schrodinger's cat). -->
    <string name="morphe_patcher_message_18">Promjena postavke nadgradnje aplikacije s neispravnog na ispravan… 📦⚛️</string>
    <!-- Throw away reference to a Saturday Night Live sketch. "fever" means sickness or the flu. "prescription" means medical treatment or can be translated from "cure" -->
    <string name="morphe_patcher_message_19">Vaša aplikacija ima groznicu, a jedini recept je više lokera… 🩺🔔</string>
    <string name="morphe_patcher_message_20">Uklanjanje smetnji. Molimo ostanite na čekanju… 🗑️</string>
