    <string name="morphe_home_download_instructions_download_button_toast">Pritisni \"download\" na stranici, a ne ovdje 😊</string>
    <string name="morphe_home_download_instructions_step3">Čekajte da se preuzimanje završi, a &lt;b&gt;ne instalirajte&lt;/b&gt; APK</string>
