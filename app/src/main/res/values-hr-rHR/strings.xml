<resources>
    <!-- Morphe Home Screen -->
    <string name="morphe_home_bundles">Paket nadopuna</string>
    <string name="morphe_home_greeting_1">Koji aplikacijom želite popraviti?</string>
    <!-- Humorous hype message with light nostalgia -->
    <string name="morphe_home_greeting_2">Gotovo da opet napravite YouTube legendarno?</string>
    <!-- "Buckle up" referring to fasten your vehicle seat belt. A light-hearted joke to build excitement. -->
    <string name="morphe_home_greeting_3">Uvijete se, sada je vrijeme za ispravke</string>
    <!-- Sarcastic joke about blocking ads, intentionally over-the-top -->
    <string name="morphe_home_greeting_4">Još jedan dan, još jedna blokirana reklama majstorstvo</string>
    <!-- "Watch ads" refers to watching video ads in unpatched apps -->
    <string name="morphe_home_greeting_5">Ne želim promatrati reklame, niti ja.</string>
    <!-- Friendly, slightly mischievous joke about controlling app behavior -->
    <string name="morphe_home_greeting_6">Pomožimo da se vaše aplikacije ponašaju</string>
    <!-- Whimsical forecast-style joke, not meant literally -->
    <string name="morphe_home_greeting_7">Danasna prognoza: 100% vjerojatnost popravki</string>
    <!-- From mediocrity to amazing -->
    <string name="morphe_home_greeting_8">Gotovo za promjenu neuzdovoljavajućeg u fantastično?</string>
    <!-- Playful exaggeration, making patching feel heroic -->
    <string name="morphe_home_greeting_9">Od danas spašavamo aplikacije od same sebe</string>
    <!-- Light sarcasm, casual and tech-savvy humor -->
    <string name="morphe_home_greeting_10">Pokrenuto kofeinom i dobrom humorom</string>
