    <!-- Dialog 2: Download Instructions -->
    <string name="morphe_home_download_instructions_title">Preuzmi originalni APK</string>
    <string name="morphe_home_download_instructions_steps_title">Upute:</string>
    <string name="morphe_home_download_instructions_step1">Pritisnite dugme \'%1$s\' ispod</string>
